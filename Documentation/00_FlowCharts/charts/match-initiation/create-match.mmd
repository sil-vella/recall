%% Create match (invite flow): frontend → backend → coordinator → match state.
%% Contrast: random-join uses join_random_game, timer or max players, coordinator fetches comp from API.
%% Create-match: 3 accepted → create_room with accepted_players + autoStart; effective max = maxSize - compCount; coordinator uses accepted_players comp list.

flowchart TD
  subgraph Frontend["Frontend (Flutter)"]
    LOB["Lobby screen"]
    WIDG["CreateJoinGameWidget / _CreateRoomModal"]
    SESS["createMatchSession → POST create-match-session"]
    SEARCH["User search: POST /userauth/users/search"]
    INV["invitePlayer with create_match_id"]
    POLL["Poll get-create-match-session"]
    THREE{"3 invited & all accepted?"}
    CREATE_BTN["Create button enabled"]
    PAY["Build roomSettings: accepted_players, autoStart: true"]
    CLEAR["clearAllGameStateBeforeNewGame"]
    WS["ensureWebSocketReady"]
    EMIT["emit create_room (accepted_players, auto_start: true)"]
    LOB --> WIDG
    WIDG --> SESS
    SESS --> SEARCH
    SEARCH --> INV
    INV --> POLL
    POLL --> THREE
    THREE -->|Yes| CREATE_BTN
    CREATE_BTN --> PAY
    PAY --> CLEAR
    CLEAR --> WS
    WS --> EMIT
  end

  subgraph PythonInvite["Backend (Python – invite)"]
    EP_INV["POST /userauth/dutch/invite-player"]
    RESOLVE["Resolve username → target user"]
    COMP{"is_comp_player?"}
    COMP_ADD["Add to session: status accepted, is_comp_player: true"]
    COMP_RET["Return: Computer player added"]
    HUMAN_NOTIF["Create instant notification dutch_invite"]
    HUMAN_ADD["Add to session: notification_id, status pending, is_comp_player: false"]
    HUMAN_RET["Return: Invite sent"]
    RESP["invite-response: Accept/Decline → update session status"]
    INV --> EP_INV
    EP_INV --> RESOLVE
    RESOLVE --> COMP
    COMP -->|Yes| COMP_ADD
    COMP -->|No| HUMAN_NOTIF
    COMP_ADD --> COMP_RET
    HUMAN_NOTIF --> HUMAN_ADD
    HUMAN_ADD --> HUMAN_RET
    HUMAN_ADD -.->|Invited human taps Accept/Decline| RESP
  end

  subgraph BackendCreate["Backend Dart – create_room"]
    MSG["message_handler: create_room"]
    HAND["_handleCreateRoom"]
    CR["roomManager.createRoom(acceptedPlayers)"]
    SUCC["send create_room_success"]
    HOOK_C["trigger room_created"]
    JOIN_E["send room_joined"]
    HOOK_J["trigger room_joined (creator)"]
    EFF_CREATE{"autoStart & currentSize >= effectiveMax?"}
    EFF_VAL["effectiveMax = maxSize - compCount"]
    START_AT_CREATE["_startMatchForRoom(roomId)"]
    EMIT --> MSG
    MSG --> HAND
    HAND --> CR
    CR --> SUCC
    SUCC --> HOOK_C
    HOOK_C --> JOIN_E
    JOIN_E --> HOOK_J
    HOOK_J --> EFF_VAL
    EFF_VAL --> EFF_CREATE
    EFF_CREATE -->|Yes| START_AT_CREATE
  end

  subgraph BackendJoin["Backend Dart – join_room"]
    JOIN_MSG["message_handler: join_room"]
    HAND_J["_handleJoinRoom"]
    JOIN_ROOM["roomManager.joinRoom"]
    SUCC_J["send join_room_success"]
    HOOK_J2["trigger room_joined"]
    EFF_JOIN{"autoStart & currentSize >= effectiveMax?"}
    START_AT_JOIN["_startMatchForRoom(roomId)"]
    JOIN_MSG --> HAND_J
    HAND_J --> JOIN_ROOM
    JOIN_ROOM --> SUCC_J
    SUCC_J --> HOOK_J2
    HOOK_J2 --> EFF_JOIN
    EFF_JOIN -->|Yes| START_AT_JOIN
  end

  subgraph StartMatch["Backend Dart – start match"]
    START_FN["_startMatchForRoom"]
    DATA["startMatchData: game_id, min/max_players, accepted_players"]
    COORD["_gameCoordinator.handle start_match"]
    START_AT_CREATE --> START_FN
    START_AT_JOIN --> START_FN
    START_FN --> DATA
    DATA --> COORD
  end

  subgraph Coordinator["Coordinator – _handleStartMatch"]
    HANDLE["game_event_coordinator.handle start_match"]
    BUILD["Build initial game_state from room_joined players"]
    HAS_ACCEPTED{"accepted_players present?"}
    USE_ACCEPTED["Add comp players from accepted_players (is_comp_player: true)"]
    FETCH_API["Fetch comp players from Flask API"]
    FILL["Fill to maxPlayers"]
    LINK["→ State construction"]
    COORD --> HANDLE
    HANDLE --> BUILD
    BUILD --> HAS_ACCEPTED
    HAS_ACCEPTED -->|Yes| USE_ACCEPTED
    HAS_ACCEPTED -->|No| FETCH_API
    USE_ACCEPTED --> FILL
    FETCH_API --> FILL
    FILL --> LINK
  end

  subgraph FrontendHooks["Frontend (hooks)"]
    RC["room_creation hook: currentRoomId, isInRoom"]
    ADD["game_state_updated → _addGameToMap"]
    NAV["Lobby or navigate to game"]
    HOOK_C --> RC
    RC --> ADD
    ADD --> NAV
  end

  style EMIT fill:#2d5a2d
  style HAND fill:#2d4a6d
  style START_FN fill:#2d4a6d
  style USE_ACCEPTED fill:#6d4a2d
  style LINK fill:#4a5a2d
  click LINK href "../game-state/state_construction.html" "Open State construction"
