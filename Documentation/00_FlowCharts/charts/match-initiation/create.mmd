flowchart TD
    subgraph Create["Create room"]
      A[User opens Create and Join] --> B[Tap Create Game set permission type password]
      B --> C[_createRoom with roomSettings]
      C --> D[LobbyScreen._createRoom]
      D --> E[clearAllGameStateBeforeNewGame]
      E --> F[checkCoinsRequirement]
      F --> G[Clear practiceUser setTransportMode websocket]
      G --> H[ensureWebSocketReady]
      H --> I[DutchGameHelpers.createRoom]
      I --> J[Emit create_room]
      J --> K[Backend creates room]
      K --> L[room_creation success is_owner]
      L --> M[State currentRoomId isRoomOwner gamePhase waiting]
      M --> N[SnackBar Room created]
      N --> O[Host stays on lobby game in Current games]
    end
    subgraph Enter["Enter and start"]
      O --> P[Host taps game in list]
      P --> Q[_enterGameRoom setCurrentGameSync]
      Q --> R[Navigate to game-play]
      R --> S[Host taps Start Match]
      S --> T[GameCoordinator.startMatch]
      T --> U[Backend start_match]
      U --> V[deal phase initial_peek]
      V --> W[game_state_updated]
    end
