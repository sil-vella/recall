flowchart TD
    subgraph Client["Flutter client"]
      A[User taps Practice Play Dutch or Clear and Collect] --> B[PracticeMatchWidget]
      B --> C[LobbyScreen._startPracticeMatch]
      C --> D[clearAllGameStateBeforeNewGame]
      D --> E[Generate practice user ID]
      E --> F[Set practiceUser and practiceSettings in state]
      F --> G[setTransportMode practice]
      G --> H[PracticeModeBridge.initialize]
      H --> I[startPracticeSession]
      I --> J[RoomManagerStub.createRoom]
      J --> K[room_created hook]
      K --> L[room_joined hook]
      L --> M[Build gameData update state]
      M --> N[handleGameStateUpdated]
      N --> O[Navigate to game-play]
    end
    subgraph GamePlay["On game-play screen"]
      O --> P[User taps Start Match]
      P --> Q[GameCoordinator.startMatch]
      Q --> R[Practice bridge start_match]
      R --> S[Deal phase initial_peek]
    end
