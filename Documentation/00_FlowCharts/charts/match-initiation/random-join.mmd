%% Random join: frontend → backend → coordinator → match state construction (link to state_construction).

flowchart TD
  subgraph Frontend["Frontend (Flutter)"]
    LOB["Lobby screen"]
    WIDG["JoinRandomGameWidget"]
    COIN["checkCoinsRequirement"]
    WS["ensureWebSocketReady"]
    CLEAR["clearAllGameStateBeforeNewGame"]
    FLAG["updateStateSync: isRandomJoinInProgress, randomJoinIsClearAndCollect"]
    EMIT["emit join_random_game / dutch_game_helpers.dart"]
    LOB --> WIDG
    WIDG --> COIN
    COIN --> WS
    WS --> CLEAR
    CLEAR --> FLAG
    FLAG --> EMIT
  end

  subgraph Backend["Backend (Dart)"]
    MSG["message_handler: join_random_game"]
    FIND["_handleJoinRandomGame / message_handler.dart"]
    AVAIL["_getAvailableRoomsForRandomJoin"]
    BRANCH{"Rooms available?"}
    JOIN["_handleJoinRoom → room_joined, hooks"]
    CREATE["createRoom, create_room_success is_random_join: true"]
    HOOKS["room_created + room_joined hooks"]
    DELAY["Schedule delayed start_match"]
    EMIT --> MSG
    MSG --> FIND
    FIND --> AVAIL
    AVAIL --> BRANCH
    BRANCH -->|Yes| JOIN
    BRANCH -->|No| CREATE
    CREATE --> HOOKS
    HOOKS --> DELAY
  end

  subgraph Frontend2["Frontend (hooks + navigate)"]
    RC["room_creation hook: update state, navigate to game-play"]
    WSJ["websocket_join_room hook: set currentGameId, wait for game_state_updated"]
    GSU["handleGameStateUpdated → add game to map"]
    NAV["Navigate to /dutch/game-play"]
    JOIN --> WSJ
    HOOKS --> RC
    RC --> NAV
    WSJ --> GSU
    GSU --> NAV
  end

  subgraph Coordinator["Coordinator (match start)"]
    START["start_match event"]
    HANDLE["coordinator.handle start_match / game_event_coordinator.dart"]
    BUILD["_handleStartMatch: build initial game_state"]
    LINK["→ State construction"]
    DELAY --> START
    START --> HANDLE
    HANDLE --> BUILD
    BUILD --> LINK
  end

  style EMIT fill:#2d5a2d
  style FIND fill:#2d4a6d
  style BUILD fill:#6d4a2d
  style LINK fill:#4a5a2d
  click LINK href "../game-state/state_construction.html" "Open State construction"
