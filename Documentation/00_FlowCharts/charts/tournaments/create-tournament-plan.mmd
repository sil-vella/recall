%% Create tournament plan – from lobby Tournaments tab.
%% Existing: only public. Create new: private, format, invite (creator auto-added, filter from search), backend creates in DB, invites accept, then notify all to join, wire into match/room/gamestate.

flowchart TD
  subgraph Lobby["Lobby screen"]
    START["Tournaments tab"]
  end

  START --> CHOICE{"Select existing or create new?"}
  CHOICE -->|Existing| EXIST["Select existing tournament"]
  CHOICE -->|Create new| NEW["Create new tournament"]

  EXIST --> PUBLIC["Only public tournaments shown"]
  PUBLIC --> EXIST_END["Open tournament or join flow"]

  NEW --> PRIVATE["Automatically private"]
  PRIVATE --> FORMAT["Select tournament format"]
  FORMAT --> FORMAT_OPTS["e.g. F1, F2, F3"]
  FORMAT_OPTS --> INVITE["Invite players"]
  INVITE --> SEARCH["User search – filter out creator username"]
  SEARCH --> CREATOR["Creator auto-added as accepted"]
  CREATOR --> COUNT["Number of invites depends on format type"]
  COUNT --> SEND["Send invites or add to tournament"]

  SEND --> BACKEND["Python backend creates tournament in DB"]
  BACKEND --> NOTE_DB["See prev commits for tournament DB"]
  NOTE_DB --> NOTIF["Invited players receive notification"]
  NOTIF --> ACCEPT["Invitees must accept notification"]
  ACCEPT --> CHECK{"Required number accepted?"}
  CHECK -->|No| ACCEPT
  CHECK -->|Yes| NOTIF_JOIN["Auto notification to all HUMAN players to join tournament"]
  NOTIF_JOIN --> WIRE["Wire into existing match logic"]
  WIRE --> ROOM["Add to room etc"]
  ROOM --> GAMESTATE["Game state: tournament keys in game map"]
  GAMESTATE --> KEYS["tournament name, format, players, etc"]
  KEYS --> MERGE["Same flow as match initiation / game play"]

  style START fill:#2d5a2d
  style CHOICE fill:#2d4a6d
  style BACKEND fill:#2d4a6d
  style GAMESTATE fill:#2d4a6d
