// Generated by Ansible — do not edit by hand; edit files/global_broadcast_messages.json and re-run the playbook.
db = db.getSiblingDB('{{ database_name }}');
var PLAYBOOK = {{ gb_messages | tojson }};
var coll = db.getCollection('{{ global_broadcast_messages_coll }}');
var reads = db.getCollection('{{ global_broadcast_reads_coll }}');
var now = new Date();

{% if not (allow_empty | default(false) | bool) %}
if (!Array.isArray(PLAYBOOK) || PLAYBOOK.length === 0) {
  print('ERROR: messages array is empty. Refusing to wipe the collection. Set -e allow_empty=true to allow.');
  quit(1);
}
{% else %}
if (!Array.isArray(PLAYBOOK)) {
  print('ERROR: seed must be a JSON array or { "messages": [...] }');
  quit(1);
}
{% endif %}

var oids = [];
var i;
for (i = 0; i < PLAYBOOK.length; i++) {
  var row = PLAYBOOK[i];
  if (!row._id) {
    print('ERROR: each message must have _id (24-char hex). Index: ' + i);
    quit(1);
  }
  oids.push(ObjectId(String(row._id)));
}

var delMsg = coll.deleteMany({ _id: { $nin: oids } });
print('Deleted orphan {{ global_broadcast_messages_coll }}: ' + delMsg.deletedCount);

{% if prune_reads | default(true) | bool %}
if (oids.length > 0) {
  var delReads = reads.deleteMany({ global_message_id: { $nin: oids } });
  print('Pruned {{ global_broadcast_reads_coll }} (orphan message ids): ' + delReads.deletedCount);
} else {
  var delAllReads = reads.deleteMany({});
  print('Cleared {{ global_broadcast_reads_coll }} (empty seed): ' + delAllReads.deletedCount);
}
{% endif %}

var PREDEFINED_TYPES = { instant: 1, admin: 1, advert: 1 };
function normTargets(arr) {
  if (!Array.isArray(arr) || arr.length === 0) return ['all'];
  var out = [];
  var j, s;
  for (j = 0; j < arr.length; j++) {
    s = String(arr[j] || '').trim().toLowerCase();
    if (!s) continue;
    if (s === 'all') return ['all'];
    out.push(s);
  }
  return out.length ? out : ['all'];
}

for (i = 0; i < PLAYBOOK.length; i++) {
  var raw = PLAYBOOK[i];
  var oid = ObjectId(String(raw._id));
  var existing = coll.findOne({ _id: oid }, { projection: { created_at: 1 } });
  var title = String(raw.title || '').trim();
  var body = String(raw.body || '').trim();
  if (!title || !body) {
    print('ERROR: title and body required for _id=' + raw._id);
    quit(1);
  }
  var ntype = String(raw.type || 'instant').trim();
  if (!PREDEFINED_TYPES[ntype]) ntype = 'instant';
  var createdAt = (existing && existing.created_at) ? existing.created_at : (raw.created_at ? new Date(raw.created_at) : now);
  var doc = {
    _id: oid,
    title: title,
    body: body,
    type: ntype,
    subtype: String(raw.subtype || '').trim(),
    source: String(raw.source || 'global_broadcast').trim(),
    data: (raw.data && typeof raw.data === 'object') ? raw.data : {},
    responses: Array.isArray(raw.responses) ? raw.responses : [],
    target_ranks: normTargets(raw.target_ranks),
    is_active: raw.is_active !== false,
    created_at: createdAt,
    updated_at: now
  };
  var mid = String(raw.msg_id || '').trim();
  if (mid) doc.msg_id = mid;
  if (raw.starts_at) doc.starts_at = new Date(raw.starts_at);
  if (raw.ends_at) doc.ends_at = new Date(raw.ends_at);
  coll.replaceOne({ _id: oid }, doc, { upsert: true });
}

print('Upserted ' + PLAYBOOK.length + ' document(s). Final count: ' + coll.countDocuments({}));
