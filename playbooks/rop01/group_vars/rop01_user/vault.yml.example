mongodb_password: ""
redis_password: ""
jwt_secret_key: ""
encryption_key: ""
dart_backend_service_key: ""
dutch_mt_dashboard_service_key: ""
google_client_id: ""
google_client_secret: ""
app_version: "2.0.0"
app_download_base_url: "https://dutch.mt/downloads"
