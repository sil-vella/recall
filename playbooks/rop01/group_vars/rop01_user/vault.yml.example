# Example variable names for VPS .env (used by 08_deploy_docker_compose.yml).
# Copy to vault.yml, fill in real values, then encrypt:
#   ansible-vault create playbooks/rop01/group_vars/rop01_user/vault.yml
# Run playbooks with: --ask-vault-pass
# Do not commit vault.yml before encrypting; after encrypting, the file is safe to commit.

