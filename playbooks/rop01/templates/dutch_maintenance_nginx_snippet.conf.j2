# Managed by Ansible playbooks/rop01/16_dutch_maintenance.yml — do not edit by hand.
# When .maintenance exists: 302 all requests to /maintenance.html except:
#   - /maintenance.html (the page itself)
#   - /downloads* (APK binaries)
# When .maintenance is absent, GET /maintenance.html redirects (302) to /.
set $dutch_maint_block 0;
if (-f {{ dutch_site_root }}/.maintenance) {
    set $dutch_maint_block 1;
}
if ($request_uri ~ "^/maintenance\.html") {
    set $dutch_maint_block 0;
}
if ($request_uri ~ "^/downloads") {
    set $dutch_maint_block 0;
}
if ($dutch_maint_block = 1) {
    return 302 /maintenance.html;
}

location = /maintenance.html {
    if (!-f {{ dutch_site_root }}/.maintenance) {
        return 302 /;
    }
    alias {{ dutch_site_root }}/maintenance.html;
}
