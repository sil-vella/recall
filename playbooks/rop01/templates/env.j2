# VPS .env for docker-compose. Generated by 08_deploy_docker_compose.yml.
# Source: app_dev/.env.prod (parsed on controller) or Ansible -e / lookup('env').
# Compose file uses env_file: .env for all services.

# VPS user (playbook sets these)
VPS_APP_UID={{ vps_app_uid | default('1000') }}
VPS_APP_GID={{ vps_app_gid | default('1000') }}

# MongoDB (Bitnami + Flask)
MONGODB_ROOT_PASSWORD={{ mongodb_root_password | default(lookup('env', 'MONGODB_ROOT_PASSWORD') | default('')) }}
MONGODB_PASSWORD={{ mongodb_password | default(lookup('env', 'MONGODB_PASSWORD') | default('')) }}

# Redis
REDIS_PASSWORD={{ redis_password | default(lookup('env', 'REDIS_PASSWORD') | default('')) }}

# Flask (JWT, encryption, service keys, Google OAuth)
JWT_SECRET_KEY={{ jwt_secret_key | default(lookup('env', 'JWT_SECRET_KEY') | default('')) }}
ENCRYPTION_KEY={{ encryption_key | default(lookup('env', 'ENCRYPTION_KEY') | default('')) }}
DART_BACKEND_SERVICE_KEY={{ dart_backend_service_key | default(lookup('env', 'DART_BACKEND_SERVICE_KEY') | default('')) }}
DUTCH_MT_DASHBOARD_SERVICE_KEY={{ dutch_mt_dashboard_service_key | default(lookup('env', 'DUTCH_MT_DASHBOARD_SERVICE_KEY') | default('')) }}
GOOGLE_CLIENT_ID={{ google_client_id | default(lookup('env', 'GOOGLE_CLIENT_ID') | default('')) }}
GOOGLE_CLIENT_SECRET={{ google_client_secret | default(lookup('env', 'GOOGLE_CLIENT_SECRET') | default('')) }}

# App version (Flask /public/check-updates)
APP_VERSION={{ app_version | default(lookup('env', 'APP_VERSION') | default('2.0.0')) }}

# Download base URL for mobile APK (Flask /public/check-updates)
APP_DOWNLOAD_BASE_URL={{ app_download_base_url | default(lookup('env', 'APP_DOWNLOAD_BASE_URL') | default('https://dutch.reignofplay.com/downloads')) }}

# Credit system API key (optional)
CREDIT_SYSTEM_API_KEY={{ credit_system_api_key | default(lookup('env', 'CREDIT_SYSTEM_API_KEY') | default('')) }}

# Dutch game SSOT (Flask + dart-game-server; compose interpolates ${DUTCH_TABLES_JSON} etc.)
DUTCH_WINS_PER_USER_LEVEL={{ dutch_wins_per_user_level | default(lookup('env', 'DUTCH_WINS_PER_USER_LEVEL') | default('10')) }}
DUTCH_LEVELS_PER_RANK={{ dutch_levels_per_rank | default(lookup('env', 'DUTCH_LEVELS_PER_RANK') | default('5')) }}
DUTCH_USER_LEVEL_MIN={{ dutch_user_level_min | default(lookup('env', 'DUTCH_USER_LEVEL_MIN') | default('1')) }}
DUTCH_RANK_HIERARCHY={{ dutch_rank_hierarchy | default(lookup('env', 'DUTCH_RANK_HIERARCHY') | default('beginner,novice,apprentice,skilled,advanced,expert,veteran,master,elite,legend')) | to_json }}
DUTCH_TABLES_JSON={{ dutch_tables_json | default(lookup('env', 'DUTCH_TABLES_JSON') | default('')) | to_json }}
REGISTRATION_COIN_BONUS={{ registration_coin_bonus | default(lookup('env', 'REGISTRATION_COIN_BONUS') | default('500')) }}

# Stripe (Checkout sessions + webhooks; python_base_04 Config). Use to_json (not shell quote) — Docker Compose .env parsing.
STRIPE_SECRET_KEY={{ stripe_secret_key | default(lookup('env', 'STRIPE_SECRET_KEY') | default('')) | to_json }}
STRIPE_PUBLISHABLE_KEY={{ stripe_publishable_key | default(lookup('env', 'STRIPE_PUBLISHABLE_KEY') | default('')) | to_json }}
STRIPE_WEBHOOK_SECRET={{ stripe_webhook_secret | default(lookup('env', 'STRIPE_WEBHOOK_SECRET') | default('')) | to_json }}
STRIPE_PRICE_COIN_STARTER={{ stripe_price_coin_starter | default(lookup('env', 'STRIPE_PRICE_COIN_STARTER') | default('')) | to_json }}
STRIPE_PRICE_COIN_CASUAL={{ stripe_price_coin_casual | default(lookup('env', 'STRIPE_PRICE_COIN_CASUAL') | default('')) | to_json }}
STRIPE_PRICE_COIN_STANDARD={{ stripe_price_coin_standard | default(lookup('env', 'STRIPE_PRICE_COIN_STANDARD') | default('')) | to_json }}
STRIPE_PRICE_COIN_POPULAR={{ stripe_price_coin_popular | default(lookup('env', 'STRIPE_PRICE_COIN_POPULAR') | default('')) | to_json }}
STRIPE_PRICE_COIN_GRINDER={{ stripe_price_coin_grinder | default(lookup('env', 'STRIPE_PRICE_COIN_GRINDER') | default('')) | to_json }}
STRIPE_PRICE_COIN_PRO={{ stripe_price_coin_pro | default(lookup('env', 'STRIPE_PRICE_COIN_PRO') | default('')) | to_json }}
STRIPE_COIN_CHECKOUT_SUCCESS_URL={{ stripe_coin_checkout_success_url | default(lookup('env', 'STRIPE_COIN_CHECKOUT_SUCCESS_URL') | default('')) | to_json }}
STRIPE_COIN_CHECKOUT_CANCEL_URL={{ stripe_coin_checkout_cancel_url | default(lookup('env', 'STRIPE_COIN_CHECKOUT_CANCEL_URL') | default('')) | to_json }}

# Google Play (Android Publisher API — verify + consume coin IAP; path must be readable inside Flask container)
GOOGLE_PLAY_PACKAGE_NAME={{ google_play_package_name | default(lookup('env', 'GOOGLE_PLAY_PACKAGE_NAME') | default('')) | to_json }}
GOOGLE_PLAY_SERVICE_ACCOUNT_FILE={{ google_play_service_account_file | default(lookup('env', 'GOOGLE_PLAY_SERVICE_ACCOUNT_FILE') | default('')) | to_json }}

# AdMob rewarded claims (Flask AdmobRewardsModule; optional — defaults in Config if unset)
ADMOB_REWARDED_COINS_PER_CLAIM={{ admob_rewarded_coins_per_claim | default(lookup('env', 'ADMOB_REWARDED_COINS_PER_CLAIM') | default('25')) }}
ADMOB_REWARDED_DAILY_CAP={{ admob_rewarded_daily_cap | default(lookup('env', 'ADMOB_REWARDED_DAILY_CAP') | default('20')) }}
