# VPS .env for docker-compose. Generated by 08_deploy_docker_compose.yml.
# Values: Ansible vars (host_vars, -e) override; else read from your environment (e.g. export or source app_dev/.env.prod before deploy).
# See app_dev/.env.example for variable names.

# VPS user (playbook sets these)
VPS_APP_UID={{ vps_app_uid | default('1000') }}
VPS_APP_GID={{ vps_app_gid | default('1000') }}

# MongoDB (Bitnami + Flask)
MONGODB_ROOT_PASSWORD={{ mongodb_root_password | default(lookup('env', 'MONGODB_ROOT_PASSWORD') | default('')) }}
MONGODB_PASSWORD={{ mongodb_password | default(lookup('env', 'MONGODB_PASSWORD') | default('')) }}

# Redis
REDIS_PASSWORD={{ redis_password | default(lookup('env', 'REDIS_PASSWORD') | default('')) }}

# Flask (JWT, encryption, service keys, Google OAuth)
JWT_SECRET_KEY={{ jwt_secret_key | default(lookup('env', 'JWT_SECRET_KEY') | default('')) }}
ENCRYPTION_KEY={{ encryption_key | default(lookup('env', 'ENCRYPTION_KEY') | default('')) }}
DART_BACKEND_SERVICE_KEY={{ dart_backend_service_key | default(lookup('env', 'DART_BACKEND_SERVICE_KEY') | default('')) }}
DUTCH_MT_DASHBOARD_SERVICE_KEY={{ dutch_mt_dashboard_service_key | default(lookup('env', 'DUTCH_MT_DASHBOARD_SERVICE_KEY') | default('')) }}
GOOGLE_CLIENT_ID={{ google_client_id | default(lookup('env', 'GOOGLE_CLIENT_ID') | default('')) }}
GOOGLE_CLIENT_SECRET={{ google_client_secret | default(lookup('env', 'GOOGLE_CLIENT_SECRET') | default('')) }}

# App version (Flask /public/check-updates)
APP_VERSION={{ app_version | default(lookup('env', 'APP_VERSION') | default('2.0.0')) }}

# Download base URL for mobile APK (Flask /public/check-updates)
APP_DOWNLOAD_BASE_URL={{ app_download_base_url | default(lookup('env', 'APP_DOWNLOAD_BASE_URL') | default('https://dutch.mt/downloads')) }}

# Credit system API key (optional)
CREDIT_SYSTEM_API_KEY={{ credit_system_api_key | default(lookup('env', 'CREDIT_SYSTEM_API_KEY') | default('')) }}
